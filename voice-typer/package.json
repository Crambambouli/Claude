{
  "name": "voice-typer",
  "version": "1.0.0",
  "description": "Voice-to-text Electron Desktop App mit lokalem Whisper STT",
  "main": "dist/main.js",
  "scripts": {
    "prebuild": "node scripts/create-icons.js",
    "build": "tsc",
    "postbuild": "node scripts/post-build.js",
    "dev": "npm run build && electronmon dist/main.js",
    "watch": "tsc -w --preserveWatchOutput",
    "start": "electron dist/main.js",
    "package": "npm run build && electron-builder",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "electron": "^30.0.4",
    "electronmon": "^2.0.2",
    "typescript": "^5.5.2",
    "electron-builder": "^24.13.3"
  },
  "electronmon": {
    "patterns": ["dist/**/*", "assets/**/*"],
    "ignore": ["**/*.map"]
  },
  "build": {
    "appId": "com.voicetyper.app",
    "productName": "Voice Typer",
    "copyright": "Copyright © 2024",
    "files": [
      "dist/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icons/app.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
